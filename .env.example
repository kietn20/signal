# database configuration
POSTGRES_USER=signal
POSTGRES_PASSWORD=signal_dev_password
POSTGRES_DB=signal_db
DATABASE_URL=postgresql://signal:signal_dev_password@localhost:5432/signal_db

# redis configuration
REDIS_URL=redis://localhost:6379

# auth configuration
JWT_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# server configuration
PORT=3001
NODE_ENV=development

# AI API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=